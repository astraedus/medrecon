FROM python:3.12-slim

WORKDIR /app

# Install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy shared code and agent code
COPY shared/ ./shared/
COPY interaction_checker/ ./interaction_checker/
ENV PORT=8002

CMD ["uvicorn", "interaction_checker.app:a2a_app", "--host", "0.0.0.0", "--port", "8002"]
