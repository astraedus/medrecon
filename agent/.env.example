# Required: Google API key for Gemini
GOOGLE_API_KEY=your-google-api-key-here

# Optional: FHIR server URL (defaults to HAPI public server)
# FHIR_SERVER_URL=https://hapi.fhir.org/baseR4

# Optional: MCP server URL (defaults to localhost:5000)
# MCP_SERVER_URL=http://localhost:5000/mcp

# Optional: Set to FALSE to use AI Studio (free tier)
# GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Multi-agent A2A URLs (for Orchestrator)
# SOURCE_COLLECTOR_URL=http://localhost:8001
# INTERACTION_CHECKER_URL=http://localhost:8002
# ORCHESTRATOR_URL=http://localhost:8003

# Optional: Agent public URLs (for agent cards)
# MEDRECON_AGENT_URL=http://localhost:8001

# Optional: Prompt Opinion platform base URL
# PO_PLATFORM_BASE_URL=https://app.promptopinion.ai
